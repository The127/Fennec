<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fennec.App.App"
             xmlns:local="using:Fennec.App"
             RequestedThemeVariant="Default"
             xmlns:themes="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <themes:ShadTheme />
        <materialIcons:MaterialIconStyles />

        <!-- Reusable floating panel style for popups (emoji picker, autocomplete) -->
        <Style Selector="Border.PopupPanel">
            <Setter Property="Background" Value="{DynamicResource ShadBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShadBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BoxShadow" Value="0 8 24 0 #30000000" />
            <Setter Property="Padding" Value="6" />
        </Style>
    </Application.Styles>
</Application>