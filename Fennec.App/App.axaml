<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fennec.App.App"
             xmlns:local="using:Fennec.App"
             RequestedThemeVariant="Default"
             xmlns:themes="clr-namespace:ShadUI;assembly=ShadUI"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.DraculaDark}" Source="avares://Fennec.App/Themes/Dracula.Dark.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.DraculaLight}" Source="avares://Fennec.App/Themes/Dracula.Light.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.NordDark}" Source="avares://Fennec.App/Themes/Nord.Dark.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.NordLight}" Source="avares://Fennec.App/Themes/Nord.Light.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.GruvboxDark}" Source="avares://Fennec.App/Themes/Gruvbox.Dark.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.GruvboxLight}" Source="avares://Fennec.App/Themes/Gruvbox.Light.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.CatppuccinMochaDark}" Source="avares://Fennec.App/Themes/CatppuccinMocha.Dark.axaml" />
                <ResourceInclude x:Key="{x:Static local:ThemeKeys.CatppuccinMochaLight}" Source="avares://Fennec.App/Themes/CatppuccinMocha.Light.axaml" />
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <themes:ShadTheme />
        <materialIcons:MaterialIconStyles />


        <!-- Reusable floating panel style for popups (emoji picker, autocomplete) -->
        <Style Selector="Border.PopupPanel">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BoxShadow" Value="0 8 24 0 #30000000" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <!-- Make flyout presenter transparent so PopupPanel styling shows through -->
        <Style Selector="FlyoutPresenter.PopupPanel">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <!-- Segmented mode toggle button (Light / Auto / Dark) -->
        <Style Selector="Button.modeButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource MutedColor}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.modeButton[Tag=True]">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="Button.modeButton[Tag=False]:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
        <Style Selector="Button.modeButton[Tag=True]:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}" />
        </Style>
    </Application.Styles>
</Application>
