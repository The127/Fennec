<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Fennec.App.Controls.FennecLogo">
    <Viewbox Stretch="Uniform">
        <Canvas Width="100" Height="100">
            <Path Fill="#F39C12" Data="M 50,45 L 20,20 L 35,45 Z" />
            <Path Fill="#F39C12" Data="M 50,45 L 80,20 L 65,45 Z" />
            <Path Fill="#E67E22" Data="M 35,45 L 65,45 L 50,80 Z" />
            <Path Fill="#2C3E50" Data="M 45,70 L 55,70 L 50,80 Z" />
        </Canvas>
    </Viewbox>
</UserControl>
