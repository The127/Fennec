<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="using:ShadUI"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:Fennec.App.ViewModels"
             x:DataType="vm:ServerViewModel"
             x:Class="Fennec.App.Views.ServerView">
    <Grid ColumnDefinitions="240 *">
        <!-- Left: Channels -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource ShadBorder}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="H4" Text="{Binding ServerName}" Margin="16,16,16,8" />
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ChannelGroups}" Margin="4,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChannelGroupItem">
                                <StackPanel>
                                    <TextBlock Classes="Muted" Text="{Binding Name}"
                                               FontSize="11" Margin="12,12,0,4" />
                                    <ItemsControl ItemsSource="{Binding Channels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ChannelItem">
                                                <Button HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Padding="12,6"
                                                        Margin="0,1"
                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SelectChannelCommand}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <mi:MaterialIcon Kind="Pound" Width="14" Height="14" Opacity="0.5"
                                                                         IsVisible="{Binding IsTextOnly}" />
                                                        <mi:MaterialIcon Kind="VolumeHigh" Width="14" Height="14" Opacity="0.5"
                                                                         IsVisible="{Binding !IsTextOnly}" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right: Chat area -->
        <DockPanel Grid.Column="1">
            <!-- Channel header -->
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource ShadBorder}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <mi:MaterialIcon Kind="Pound" Width="16" Height="16" Opacity="0.5" />
                    <TextBlock Classes="H4" Text="{Binding SelectedChannel.Name}" />
                </StackPanel>
            </Border>

            <!-- Message input -->
            <Border DockPanel.Dock="Bottom" Padding="16,8"
                    IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBox Watermark="{Binding SelectedChannel.Name, StringFormat='Message #{0}'}"
                         Text="{Binding MessageText}"
                         KeyDown="MessageBox_KeyDown"
                         Classes="Clearable" />
            </Border>

            <!-- Messages or placeholder -->
            <Panel>
                <!-- Placeholder when no channel selected -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNull}}">
                    <mi:MaterialIcon Kind="MessageText" Width="48" Height="48" Opacity="0.3"
                                     HorizontalAlignment="Center" />
                    <TextBlock Classes="Muted" Text="Select a channel to start chatting"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Message list -->
                <ScrollViewer IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="16,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageItem">
                                <StackPanel>
                                    <!-- Author header (avatar + name) — only shown for first message in a group -->
                                    <StackPanel Orientation="Horizontal" Spacing="10"
                                                Margin="0,12,0,4"
                                                IsVisible="{Binding ShowAuthor}">
                                        <shadui:Avatar Fallback="{Binding AvatarFallback}" Height="32" Width="32" />
                                        <TextBlock Text="{Binding AuthorName}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Message content -->
                                    <Border Background="{DynamicResource ShadMuted}"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            Margin="42,2,48,2">
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </DockPanel>
    </Grid>
</UserControl>
