<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="using:ShadUI"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:conv="using:Fennec.App.Converters"
             xmlns:controls="using:Fennec.App.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:views="using:Fennec.App.Views"
             xmlns:vm="using:Fennec.App.ViewModels"
             x:DataType="vm:ServerViewModel"
             x:Class="Fennec.App.Views.ServerView">
    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="SelectedBackgroundConverter"
                                   TrueBrush="#20808080"
                                   FalseBrush="Transparent" />
        <conv:BoolToBrushConverter x:Key="OverLimitBrushConverter"
                                   TrueBrush="#E74C3C"
                                   FalseBrush="#A0A0A0" />
        <conv:BoolToFontSizeConverter x:Key="EmojiOnlyFontSizeConverter"
                                      TrueSize="30"
                                      FalseSize="15" />
        <conv:StringEqualsConverter x:Key="StringEqualsConverter" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Border.selected">
            <Setter Property="Background" Value="{DynamicResource InfoColor20}" />
        </Style>
    </UserControl.Styles>
    <Panel>
    <Grid ColumnDefinitions="240 * 220"
          IsVisible="{Binding !IsScreenShareMaximized}">
        <!-- Left: Channels -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="H4" Text="{Binding ServerName}" Margin="16,16,16,8">
                    <TextBlock.ContextFlyout>
                        <MenuFlyout>
                            <MenuItem Header="Add Group" Command="{Binding CreateChannelGroupCommand}" />
                        </MenuFlyout>
                    </TextBlock.ContextFlyout>
                </TextBlock>

                <!-- SignalR connection status (docked at very bottom) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"
                                Background="{Binding HubStatusColor}" />
                        <TextBlock Text="{Binding HubStatusText}" FontSize="10" Opacity="0.7"
                                   VerticalAlignment="Center" />
                        <TextBlock FontSize="10" Opacity="0.5" VerticalAlignment="Center"
                                   IsVisible="{Binding SubscribedChannelName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="· #{0}">
                                    <Binding Path="SubscribedChannelName" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Voice control bar (docked at bottom when connected) -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6"
                        IsVisible="{Binding IsInVoiceChannel}">
                    <Grid ColumnDefinitions="* Auto Auto Auto Auto Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Voice Connected" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessColor}" />
                            <TextBlock Text="{Binding CurrentVoiceChannelName}" FontSize="11" Classes="Muted"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="Ghost" Padding="6" Width="32" Height="32"
                                Command="{Binding ToggleMuteCommand}"
                                ToolTip.Tip="Toggle Mute">
                            <Panel>
                                <mi:MaterialIcon Kind="Microphone" Width="16" Height="16"
                                                 IsVisible="{Binding !IsMuted}" />
                                <mi:MaterialIcon Kind="MicrophoneOff" Width="16" Height="16"
                                                 Foreground="{DynamicResource ErrorColor}"
                                                 IsVisible="{Binding IsMuted}" />
                            </Panel>
                        </Button>
                        <Button Grid.Column="2" Classes="Ghost" Padding="6" Width="32" Height="32"
                                Command="{Binding ToggleDeafenCommand}"
                                ToolTip.Tip="Toggle Deafen">
                            <Panel>
                                <mi:MaterialIcon Kind="VolumeHigh" Width="16" Height="16"
                                                 IsVisible="{Binding !IsDeafened}" />
                                <mi:MaterialIcon Kind="VolumeOff" Width="16" Height="16"
                                                 Foreground="{DynamicResource ErrorColor}"
                                                 IsVisible="{Binding IsDeafened}" />
                            </Panel>
                        </Button>
                        <Button Grid.Column="3" Classes="Ghost" Padding="6" Width="32" Height="32"
                                Command="{Binding StartScreenShareCommand}"
                                IsVisible="{Binding !IsScreenSharing}"
                                ToolTip.Tip="Share Screen">
                            <mi:MaterialIcon Kind="MonitorShare" Width="16" Height="16" />
                        </Button>
                        <Button Grid.Column="3" Classes="Ghost" Padding="6" Width="32" Height="32"
                                Command="{Binding StopScreenShareCommand}"
                                IsVisible="{Binding IsScreenSharing}"
                                ToolTip.Tip="Stop Sharing">
                            <mi:MaterialIcon Kind="MonitorOff" Width="16" Height="16"
                                             Foreground="{DynamicResource ErrorColor}" />
                        </Button>
                        <Button Grid.Column="4" Classes="Ghost" Padding="6" Width="32" Height="32"
                                IsVisible="{Binding IsScreenSharing}"
                                ToolTip.Tip="Share Settings">
                            <mi:MaterialIcon Kind="Cog" Width="16" Height="16" />
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel Spacing="12" Width="280" Margin="8">
                                        <TextBlock Text="Share Settings" FontWeight="SemiBold" FontSize="14" />
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Resolution" FontSize="12" Classes="Muted" />
                                            <ComboBox ItemsSource="{Binding ShareResolutionOptions}"
                                                      SelectedItem="{Binding ShareResolution}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Frame Rate" FontSize="12" Classes="Muted" />
                                            <ComboBox ItemsSource="{Binding ShareFrameRateOptions}"
                                                      SelectedItem="{Binding ShareFrameRate}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="12" Classes="Muted">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Bitrate ({0} Kbps)">
                                                        <Binding Path="ShareBitrateKbps" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <Slider Minimum="500" Maximum="50000"
                                                    Value="{Binding ShareBitrateKbps}"
                                                    TickFrequency="500"
                                                    IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                        <Button Content="Apply" Classes="Primary"
                                                Command="{Binding UpdateScreenShareSettingsCommand}"
                                                HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Grid.Column="5" Classes="Ghost" Padding="6" Width="32" Height="32"
                                Command="{Binding LeaveVoiceChannelCommand}"
                                ToolTip.Tip="Disconnect">
                            <mi:MaterialIcon Kind="PhoneHangup" Width="16" Height="16"
                                             Foreground="{DynamicResource ErrorColor}" />
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer>
                    <StackPanel Margin="4,0">
                        <ItemsControl ItemsSource="{Binding ChannelGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChannelGroupItem">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="* Auto" Margin="12,12,8,4">
                                            <!-- Display name (visible when not renaming) -->
                                            <TextBlock Classes="Muted" Text="{Binding Name}" FontSize="11"
                                                       IsVisible="{Binding !IsRenaming}">
                                                <TextBlock.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Rename"
                                                                  Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).StartRenameChannelGroupCommand}"
                                                                  CommandParameter="{Binding}" />
                                                    </MenuFlyout>
                                                </TextBlock.ContextFlyout>
                                            </TextBlock>
                                            <!-- Rename input (visible when renaming) -->
                                            <TextBox Grid.Column="0" FontSize="11" Padding="4,2"
                                                     Text="{Binding RenamingText}"
                                                     IsVisible="{Binding IsRenaming}"
                                                     KeyDown="RenameChannelGroup_KeyDown" />
                                            <Button Grid.Column="1" Padding="2" Height="18" Width="18"
                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).ShowAddChannelDialogCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Add channel">
                                                <mi:MaterialIcon Kind="Plus" Width="12" Height="12" Opacity="0.5" />
                                            </Button>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Channels}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ChannelItem">
                                                    <StackPanel>
                                                        <Border CornerRadius="4"
                                                                Margin="0,1"
                                                                DoubleTapped="OnChannelDoubleTapped"
                                                                Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}">
                                                            <Button HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Padding="12,6"
                                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SelectChannelCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <Button.ContextFlyout>
                                                                    <MenuFlyout>
                                                                        <MenuItem Header="Join Voice"
                                                                                  IsVisible="{Binding !IsTextOnly}"
                                                                                  Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).JoinVoiceChannelCommand}"
                                                                                  CommandParameter="{Binding}" />
                                                                    </MenuFlyout>
                                                                </Button.ContextFlyout>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <mi:MaterialIcon Kind="Pound" Width="14" Height="14"
                                                                                     IsVisible="{Binding IsTextOnly}" />
                                                                    <mi:MaterialIcon Kind="VolumeHigh" Width="14" Height="14"
                                                                                     IsVisible="{Binding !IsTextOnly}" />
                                                                    <TextBlock Text="{Binding Name}" />
                                                                </StackPanel>
                                                            </Button>
                                                        </Border>
                                                        <!-- Voice participants under voice-enabled channels -->
                                                        <ItemsControl ItemsSource="{Binding VoiceParticipants}"
                                                                      Margin="28,0,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:VoiceParticipantItem">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                                                Margin="0,2">
                                                                        <Button Padding="0" MinWidth="0" MinHeight="0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent" BorderThickness="0">
                                                                            <Button.Styles>
                                                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                                    <Setter Property="Background" Value="Transparent" />
                                                                                </Style>
                                                                            </Button.Styles>
                                                                            <Button.Flyout>
                                                                                <Flyout Placement="RightEdgeAlignedTop"
                                                                                        FlyoutPresenterClasses="PopupPanel">
                                                                                    <Border Classes="PopupPanel" Padding="12" MinWidth="200">
                                                                                        <StackPanel Spacing="12">
                                                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                                                <shadui:Avatar Fallback="{Binding Username[0]}" Height="40" Width="40" />
                                                                                                <StackPanel VerticalAlignment="Center">
                                                                                                    <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="15" />
                                                                                                    <TextBlock Text="{Binding Identity}" Classes="Muted" FontSize="12" />
                                                                                                </StackPanel>
                                                                                            </StackPanel>
                                                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                                                <Button Classes="Primary" Padding="8,4"
                                                                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).AddFriendCommand}">
                                                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                                                        <mi:MaterialIcon Kind="AccountPlus" Width="14" Height="14" />
                                                                                                        <TextBlock Text="Add Friend" FontSize="12" />
                                                                                                    </StackPanel>
                                                                                                </Button>
                                                                                                <Button Classes="Primary" Padding="8,4"
                                                                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SendDirectMessageCommand}">
                                                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                                                        <mi:MaterialIcon Kind="MessageText" Width="14" Height="14" />
                                                                                                        <TextBlock Text="Message" FontSize="12" />
                                                                                                    </StackPanel>
                                                                                                </Button>
                                                                                                <Button Classes="Primary" Padding="8,4"
                                                                                                        IsVisible="{Binding IsScreenSharing}"
                                                                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).WatchScreenShareCommand}"
                                                                                                        CommandParameter="{Binding UserId}">
                                                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                                                        <mi:MaterialIcon Kind="MonitorShare" Width="14" Height="14" />
                                                                                                        <TextBlock Text="Watch Stream" FontSize="12" />
                                                                                                    </StackPanel>
                                                                                                </Button>
                                                                                            </StackPanel>
                                                                                        </StackPanel>
                                                                                    </Border>
                                                                                </Flyout>
                                                                            </Button.Flyout>
                                                                            <Border BorderThickness="2" CornerRadius="9" Width="18" Height="18"
                                                                                    Classes.Speaking="{Binding IsSpeaking}">
                                                                                <Border.Styles>
                                                                                    <Style Selector="Border">
                                                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                                                    </Style>
                                                                                    <Style Selector="Border.Speaking">
                                                                                        <Setter Property="BorderBrush" Value="#4CAF50" />
                                                                                    </Style>
                                                                                </Border.Styles>
                                                                                <mi:MaterialIcon Kind="AccountCircle" Width="14" Height="14"
                                                                                                 Opacity="0.5" />
                                                                            </Border>
                                                                        </Button>
                                                                        <TextBlock Text="{Binding Username}" FontSize="12"
                                                                                   Opacity="0.7" />
                                                                        <!-- Peer connection state indicators -->
                                                                        <mi:MaterialIcon Kind="Loading" Width="10" Height="10"
                                                                                         Opacity="0.4"
                                                                                         ToolTip.Tip="Connecting...">
                                                                            <mi:MaterialIcon.IsVisible>
                                                                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                                                    <Binding Path="PeerState" Converter="{x:Static StringConverters.IsNullOrEmpty}" FallbackValue="False" />
                                                                                    <Binding Path="PeerState" ConverterParameter="new" Converter="{StaticResource StringEqualsConverter}" FallbackValue="False" />
                                                                                    <Binding Path="PeerState" ConverterParameter="connecting" Converter="{StaticResource StringEqualsConverter}" FallbackValue="False" />
                                                                                </MultiBinding>
                                                                            </mi:MaterialIcon.IsVisible>
                                                                        </mi:MaterialIcon>
                                                                        <mi:MaterialIcon Kind="AlertCircle" Width="10" Height="10"
                                                                                         Foreground="#E74C3C"
                                                                                         ToolTip.Tip="Connection failed">
                                                                            <mi:MaterialIcon.IsVisible>
                                                                                <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                                                                    <Binding Path="PeerState" ConverterParameter="failed" Converter="{StaticResource StringEqualsConverter}" FallbackValue="False" />
                                                                                    <Binding Path="PeerState" ConverterParameter="disconnected" Converter="{StaticResource StringEqualsConverter}" FallbackValue="False" />
                                                                                </MultiBinding>
                                                                            </mi:MaterialIcon.IsVisible>
                                                                        </mi:MaterialIcon>
                                                                        <mi:MaterialIcon Kind="MicrophoneOff" Width="12" Height="12"
                                                                                         Opacity="0.5"
                                                                                         IsVisible="{Binding IsMuted}" />
                                                                        <mi:MaterialIcon Kind="VolumeOff" Width="12" Height="12"
                                                                                         Opacity="0.5"
                                                                                         IsVisible="{Binding IsDeafened}" />
                                                                        <Button Padding="0" MinWidth="0" MinHeight="0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent" BorderThickness="0"
                                                                                IsVisible="{Binding IsScreenSharing}"
                                                                                Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).WatchScreenShareCommand}"
                                                                                CommandParameter="{Binding UserId}"
                                                                                ToolTip.Tip="Watch Stream">
                                                                            <Button.Styles>
                                                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                                                    <Setter Property="Background" Value="Transparent" />
                                                                                </Style>
                                                                            </Button.Styles>
                                                                            <mi:MaterialIcon Kind="MonitorShare" Width="12" Height="12"
                                                                                             Opacity="0.5" />
                                                                        </Button>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right: Chat area -->
        <DockPanel Grid.Column="1">
            <!-- Channel header -->
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <mi:MaterialIcon Kind="Pound" Width="16" Height="16" Opacity="0.5" />
                    <TextBlock Classes="H4" Text="{Binding SelectedChannel.Name}" />
                </StackPanel>
            </Border>

            <!-- Message input -->
            <Border DockPanel.Dock="Bottom" Padding="16,8"
                    IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Panel>
                    <Popup x:Name="AutocompletePopup"
                           PlacementTarget="{Binding #MessageTextBox}"
                           Placement="Top"
                           IsLightDismissEnabled="False"
                           IsOpen="False">
                        <views:ShortcodeAutocompleteView x:Name="AutocompleteView" />
                    </Popup>
                    <Popup x:Name="MentionAutocompletePopup"
                           PlacementTarget="{Binding #MessageTextBox}"
                           Placement="Top"
                           IsLightDismissEnabled="False"
                           IsOpen="False">
                        <views:MentionAutocompleteView x:Name="MentionAutocompleteView" />
                    </Popup>
                    <Border BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource LgCornerRadius}"
                            Padding="0,4">
                        <Border.Styles>
                            <Style Selector="TextBox.Naked /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="TextBox.Naked:pointerover /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="TextBox.Naked:focus /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </Border.Styles>
                        <Grid RowDefinitions="Auto * Auto">
                            <!-- Attachment preview strip -->
                            <ItemsControl Grid.Row="0" ItemsSource="{Binding Attachments}"
                                          IsVisible="{Binding Attachments.Count}"
                                          Margin="8,4,8,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AttachmentItem">
                                        <Border Background="{DynamicResource SecondaryColor50}"
                                                CornerRadius="6" Padding="8,4" Margin="0,0,4,4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="File" Width="14" Height="14" Opacity="0.7"
                                                                 VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                                           VerticalAlignment="Center" MaxWidth="160"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Classes="Ghost" Padding="2" MinWidth="0" MinHeight="0"
                                                        Width="18" Height="18"
                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).RemoveAttachmentCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Remove">
                                                    <mi:MaterialIcon Kind="Close" Width="12" Height="12" Opacity="0.5" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Grid.Row="1" ColumnDefinitions="* Auto Auto Auto" MinHeight="32">
                                <TextBox x:Name="MessageTextBox"
                                         Classes="Naked"
                                         Watermark="{Binding SelectedChannel.Name, StringFormat='Message #{0}'}"
                                         Text="{Binding MessageText}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         FontSize="15"
                                         FontFamily="Inter"
                                         Padding="14,8"
                                         shadui:ControlAssist.Height="100" />
                                <Button x:Name="AttachFileButton"
                                        Grid.Column="1"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="2,4,0,0"
                                        Padding="0"
                                        ToolTip.Tip="Attach file"
                                        Click="AttachFileButton_Click">
                                    <mi:MaterialIcon Kind="Paperclip" Width="18" Height="18" Opacity="0.5" />
                                </Button>
                                <Button x:Name="EmojiButton"
                                        Grid.Column="2"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="2,4,0,0"
                                        Padding="0"
                                        ToolTip.Tip="Emoji">
                                    <Button.Flyout>
                                        <Flyout Placement="TopEdgeAlignedRight" ShowMode="TransientWithDismissOnPointerMoveAway"
                                               FlyoutPresenterClasses="PopupPanel">
                                            <views:EmojiPickerView x:Name="EmojiPicker" />
                                        </Flyout>
                                    </Button.Flyout>
                                    <TextBlock FontSize="20" Text="&#x1F60A;" FontFamily="{StaticResource EmojiFont}" />
                                </Button>
                                <Button Grid.Column="3"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="0,4,6,0"
                                        Padding="0"
                                        ToolTip.Tip="Send"
                                        Command="{Binding SendMessageCommand}">
                                    <mi:MaterialIcon Kind="Send" Width="18" Height="18" Opacity="0.5" />
                                </Button>
                            </Grid>
                            <TextBlock Grid.Row="2"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,4"
                                       FontSize="11"
                                       IsVisible="{Binding ShowCharCount}"
                                       Text="{Binding MessageCharsRemaining, StringFormat='{}{0}'}"
                                       Foreground="{Binding IsOverLimit, Converter={StaticResource OverLimitBrushConverter}}"
                                       Opacity="0.7" />
                        </Grid>
                    </Border>
                </Panel>
            </Border>

            <!-- Screen share viewer (shown when watching shares, hidden when maximized) -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Background="#1A000000"
                    Height="300">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="HasWatchedShares" />
                        <Binding Path="!IsScreenShareMaximized" />
                    </MultiBinding>
                </Border.IsVisible>
                <Grid>
                    <!-- Screen share content -->
                    <controls:ScreenShareViewer Source="{Binding ScreenShareFrame}"
                                                CursorX="{Binding CursorX}"
                                                CursorY="{Binding CursorY}"
                                                CursorShape="{Binding CursorShape}"
                                                CursorVisible="{Binding CursorVisible}"
                                                ShowDebugOverlay="{Binding ShowDebugOverlay}"
                                                DebugMetrics="{Binding DebugMetrics}" />
                    <!-- Share info bar at top -->
                    <Border VerticalAlignment="Top" Padding="8,4"
                            Background="#80000000">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                                <Button Classes="Ghost" Padding="4" Height="24"
                                        Command="{Binding ToggleShowOwnScreenShareCommand}"
                                        ToolTip.Tip="Show Own Stream">
                                    <Panel>
                                        <mi:MaterialIcon Kind="Eye" Width="14" Height="14"
                                                         IsVisible="{Binding ShowOwnScreenShare}" />
                                        <mi:MaterialIcon Kind="EyeOff" Width="14" Height="14"
                                                         IsVisible="{Binding !ShowOwnScreenShare}" />
                                    </Panel>
                                </Button>
                                <Button Classes="Ghost" Padding="4" Height="24"
                                        Command="{Binding PopOutScreenShareCommand}"
                                        ToolTip.Tip="Pop Out">
                                    <mi:MaterialIcon Kind="OpenInNew" Width="14" Height="14" />
                                </Button>
                                <Button Classes="Ghost" Padding="4" Height="24"
                                        Command="{Binding ToggleScreenShareMaximizeCommand}"
                                        ToolTip.Tip="Maximize">
                                    <mi:MaterialIcon Kind="ArrowExpand" Width="14" Height="14" />
                                </Button>
                                <Button Classes="Ghost" Padding="4" Height="24"
                                        Command="{Binding ToggleTileViewCommand}"
                                        ToolTip.Tip="Toggle Tile View">
                                    <mi:MaterialIcon Kind="ViewGrid" Width="14" Height="14" />
                                </Button>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding WatchedScreenShares}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Classes="Ghost" Padding="4,2" Height="22"
                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).FocusScreenShareCommand}"
                                                    CommandParameter="{Binding UserId}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <mi:MaterialIcon Kind="Monitor" Width="12" Height="12" />
                                                    <TextBlock Text="{Binding Username}" FontSize="11" />
                                                </StackPanel>
                                            </Button>
                                            <Button Classes="Ghost" Padding="3" Height="22"
                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).UnwatchScreenShareCommand}"
                                                    CommandParameter="{Binding UserId}"
                                                    ToolTip.Tip="Stop Watching">
                                                <mi:MaterialIcon Kind="MonitorOff" Width="12" Height="12"
                                                                 Foreground="{DynamicResource ErrorColor}" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Messages or placeholder -->
            <Panel>
                <!-- Placeholder when no channel selected -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNull}}">
                    <mi:MaterialIcon Kind="MessageText" Width="48" Height="48" Opacity="0.3"
                                     HorizontalAlignment="Center" />
                    <TextBlock Classes="Muted" Text="Select a channel to start chatting"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Message list -->
                <ScrollViewer x:Name="MessageScrollViewer" IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="16,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageItem">
                                <StackPanel>
                                    <!-- Time separator for messages with a gap -->
                                    <Grid ColumnDefinitions="* Auto *" Margin="0,16,0,4"
                                          IsVisible="{Binding ShowTimeSeparator}">
                                        <Separator Grid.Column="0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding TimeSeparatorText}"
                                                   Classes="Muted" FontSize="12" Margin="12,0" />
                                        <Separator Grid.Column="2" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Author header (avatar + name) — only shown for first message in a group -->
                                    <StackPanel Orientation="Horizontal" Spacing="10"
                                                Margin="0,12,0,4"
                                                IsVisible="{Binding ShowAuthor}">
                                        <Button Padding="0" MinWidth="0" MinHeight="0"
                                                CornerRadius="16" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="Transparent" />
                                                </Style>
                                            </Button.Styles>
                                            <Button.Flyout>
                                                <Flyout Placement="RightEdgeAlignedTop"
                                                        FlyoutPresenterClasses="PopupPanel">
                                                    <Border Classes="PopupPanel" Padding="12" MinWidth="200">
                                                        <StackPanel Spacing="12">
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <shadui:Avatar Fallback="{Binding AvatarFallback}" Height="40" Width="40" />
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding AuthorName}" FontWeight="SemiBold" FontSize="15" />
                                                                    <TextBlock Text="{Binding AuthorIdentity}" Classes="Muted" FontSize="12" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <Button Classes="Primary" Padding="8,4"
                                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).AddFriendCommand}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <mi:MaterialIcon Kind="AccountPlus" Width="14" Height="14" />
                                                                        <TextBlock Text="Add Friend" FontSize="12" />
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Classes="Primary" Padding="8,4"
                                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SendDirectMessageCommand}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <mi:MaterialIcon Kind="MessageText" Width="14" Height="14" />
                                                                        <TextBlock Text="Message" FontSize="12" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </Flyout>
                                            </Button.Flyout>
                                            <shadui:Avatar Fallback="{Binding AvatarFallback}" Height="32" Width="32" />
                                        </Button>
                                        <TextBlock Text="{Binding AuthorName}" FontWeight="SemiBold"
                                                   FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LocalTime}" Classes="Muted" FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Message content -->
                                    <Border CornerRadius="8"
                                            Padding="12,8"
                                            Margin="42,2,48,2"
                                            ToolTip.Tip="{Binding ExactTime}"
                                            Background="{DynamicResource SecondaryColor50}"
                                            Classes.selected="{Binding IsSelected}"
                                            Classes.pending="{Binding IsPending}"
                                            Classes.failed="{Binding IsSendFailed}"
                                            PointerPressed="OnMessagePressed">
                                        <Border.Styles>
                                            <Style Selector="Border.pending">
                                                <Setter Property="Opacity" Value="0.6" />
                                            </Style>
                                            <Style Selector="Border.failed">
                                                <Setter Property="Background" Value="{DynamicResource ErrorColor20}" />
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                                <controls:MessageContentControl MessageText="{Binding Content}"
                                                                                     IsEmojiOnly="{Binding IsEmojiOnly}"
                                                                                     VerticalAlignment="Center" />
                                                <mi:MaterialIcon Kind="ClockOutline" Width="14" Height="14"
                                                                 Opacity="0.5" VerticalAlignment="Center"
                                                                 IsVisible="{Binding IsPending}" />
                                                <mi:MaterialIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                                                 Foreground="{DynamicResource ErrorColor}"
                                                                 VerticalAlignment="Center"
                                                                 IsVisible="{Binding IsSendFailed}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    VerticalAlignment="Top"
                                                    Padding="4" Margin="4,0,0,0"
                                                    Cursor="Hand"
                                                    Opacity="0"
                                                    Classes="ghost"
                                                    Tag="{Binding Content}"
                                                    Click="OnCopyMessageClick">
                                                <Button.Styles>
                                                    <Style Selector="Border:pointerover Button">
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </Style>
                                                    <Style Selector="Border:pointerover Button:pointerover">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Style>
                                                </Button.Styles>
                                                <mi:MaterialIcon Kind="ContentCopy" Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </DockPanel>

        <!-- Right: Member list -->
        <Border Grid.Column="2" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="H4" Text="Members" Margin="16,16,16,8" />
                <ScrollViewer>
                    <StackPanel Margin="8,0">
                        <!-- Online section -->
                        <TextBlock Classes="Muted" FontSize="11" Margin="8,8,0,4">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="ONLINE — {0}">
                                    <Binding Path="OnlineMemberCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding OnlineMembers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MemberItem">
                                    <Button HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,4" Margin="0,1">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryColor50}" />
                                            </Style>
                                        </Button.Styles>
                                        <Button.Flyout>
                                            <Flyout Placement="LeftEdgeAlignedTop"
                                                    FlyoutPresenterClasses="PopupPanel">
                                                <Border Classes="PopupPanel" Padding="12" MinWidth="200">
                                                    <StackPanel Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <shadui:Avatar Fallback="{Binding Username[0]}" Height="40" Width="40" />
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="15" />
                                                                <TextBlock Text="{Binding Identity}" Classes="Muted" FontSize="12" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Button Classes="Primary" Padding="8,4"
                                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).AddFriendCommand}">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <mi:MaterialIcon Kind="AccountPlus" Width="14" Height="14" />
                                                                    <TextBlock Text="Add Friend" FontSize="12" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="Primary" Padding="8,4"
                                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SendDirectMessageCommand}">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <mi:MaterialIcon Kind="MessageText" Width="14" Height="14" />
                                                                    <TextBlock Text="Message" FontSize="12" />
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Panel>
                                                <shadui:Avatar Fallback="{Binding Username[0]}" Height="28" Width="28" />
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="#4CAF50"
                                                        BorderBrush="{DynamicResource BackgroundColor}"
                                                        BorderThickness="2"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,-1,-1" />
                                            </Panel>
                                            <TextBlock Text="{Binding Username}" FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Offline section -->
                        <TextBlock Classes="Muted" FontSize="11" Margin="8,12,0,4">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="OFFLINE — {0}">
                                    <Binding Path="OfflineMemberCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding OfflineMembers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:MemberItem">
                                    <Button HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,4" Margin="0,1"
                                            Opacity="0.5">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="{DynamicResource SecondaryColor50}" />
                                            </Style>
                                        </Button.Styles>
                                        <Button.Flyout>
                                            <Flyout Placement="LeftEdgeAlignedTop"
                                                    FlyoutPresenterClasses="PopupPanel">
                                                <Border Classes="PopupPanel" Padding="12" MinWidth="200">
                                                    <StackPanel Spacing="12">
                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <shadui:Avatar Fallback="{Binding Username[0]}" Height="40" Width="40" />
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Username}" FontWeight="SemiBold" FontSize="15" />
                                                                <TextBlock Text="{Binding Identity}" Classes="Muted" FontSize="12" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Button Classes="Primary" Padding="8,4"
                                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).AddFriendCommand}">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <mi:MaterialIcon Kind="AccountPlus" Width="14" Height="14" />
                                                                    <TextBlock Text="Add Friend" FontSize="12" />
                                                                </StackPanel>
                                                            </Button>
                                                            <Button Classes="Primary" Padding="8,4"
                                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SendDirectMessageCommand}">
                                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                                    <mi:MaterialIcon Kind="MessageText" Width="14" Height="14" />
                                                                    <TextBlock Text="Message" FontSize="12" />
                                                                </StackPanel>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Panel>
                                                <shadui:Avatar Fallback="{Binding Username[0]}" Height="28" Width="28" />
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                        Background="#808080"
                                                        BorderBrush="{DynamicResource BackgroundColor}"
                                                        BorderThickness="2"
                                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                        Margin="0,0,-1,-1" />
                                            </Panel>
                                            <TextBlock Text="{Binding Username}" FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>

    <!-- Maximized screen share overlay -->
    <Grid IsVisible="{Binding IsScreenShareMaximized}" Background="{DynamicResource BackgroundColor}">
        <controls:ScreenShareViewer Source="{Binding ScreenShareFrame}"
                                    CursorX="{Binding CursorX}"
                                    CursorY="{Binding CursorY}"
                                    CursorShape="{Binding CursorShape}"
                                    CursorVisible="{Binding CursorVisible}"
                                    ShowDebugOverlay="{Binding ShowDebugOverlay}"
                                    DebugMetrics="{Binding DebugMetrics}" />
        <!-- Top info bar -->
        <Border VerticalAlignment="Top" Padding="8,4"
                Background="#80000000">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Button Classes="Ghost" Padding="4" Height="24"
                            Command="{Binding ToggleShowOwnScreenShareCommand}"
                            ToolTip.Tip="Show Own Stream">
                        <Panel>
                            <mi:MaterialIcon Kind="Eye" Width="14" Height="14"
                                             IsVisible="{Binding ShowOwnScreenShare}" />
                            <mi:MaterialIcon Kind="EyeOff" Width="14" Height="14"
                                             IsVisible="{Binding !ShowOwnScreenShare}" />
                        </Panel>
                    </Button>
                    <Button Classes="Ghost" Padding="4" Height="24"
                            Command="{Binding PopOutScreenShareCommand}"
                            ToolTip.Tip="Pop Out">
                        <mi:MaterialIcon Kind="OpenInNew" Width="14" Height="14" />
                    </Button>
                    <Button Classes="Ghost" Padding="4" Height="24"
                            Command="{Binding ExitScreenShareMaximizeCommand}"
                            ToolTip.Tip="Exit Maximize (Esc)">
                        <mi:MaterialIcon Kind="ArrowCollapse" Width="14" Height="14" />
                    </Button>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding WatchedScreenShares}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Classes="Ghost" Padding="4,2" Height="22"
                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).FocusScreenShareCommand}"
                                        CommandParameter="{Binding UserId}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <mi:MaterialIcon Kind="Monitor" Width="12" Height="12" />
                                        <TextBlock Text="{Binding Username}" FontSize="11" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="Ghost" Padding="3" Height="22"
                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).UnwatchScreenShareCommand}"
                                        CommandParameter="{Binding UserId}"
                                        ToolTip.Tip="Stop Watching">
                                    <mi:MaterialIcon Kind="MonitorOff" Width="12" Height="12"
                                                     Foreground="{DynamicResource ErrorColor}" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
    </Grid>
    </Panel>
</UserControl>
