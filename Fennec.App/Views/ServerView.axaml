<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="using:ShadUI"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:conv="using:Fennec.App.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:views="using:Fennec.App.Views"
             xmlns:vm="using:Fennec.App.ViewModels"
             x:DataType="vm:ServerViewModel"
             x:Class="Fennec.App.Views.ServerView">
    <UserControl.Resources>
        <conv:BoolToBrushConverter x:Key="SelectedBackgroundConverter"
                                   TrueBrush="#20808080"
                                   FalseBrush="Transparent" />
        <conv:BoolToBrushConverter x:Key="OverLimitBrushConverter"
                                   TrueBrush="#E74C3C"
                                   FalseBrush="#A0A0A0" />
        <conv:BoolToFontSizeConverter x:Key="EmojiOnlyFontSizeConverter"
                                      TrueSize="30"
                                      FalseSize="15" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Border.selected">
            <Setter Property="Background" Value="{DynamicResource InfoColor20}" />
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="240 *">
        <!-- Left: Channels -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="H4" Text="{Binding ServerName}" Margin="16,16,16,8">
                    <TextBlock.ContextFlyout>
                        <MenuFlyout>
                            <MenuItem Header="Add Group" Command="{Binding CreateChannelGroupCommand}" />
                        </MenuFlyout>
                    </TextBlock.ContextFlyout>
                </TextBlock>
                <ScrollViewer>
                    <StackPanel Margin="4,0">
                        <ItemsControl ItemsSource="{Binding ChannelGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChannelGroupItem">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="* Auto" Margin="12,12,8,4">
                                            <!-- Display name (visible when not renaming) -->
                                            <TextBlock Classes="Muted" Text="{Binding Name}" FontSize="11"
                                                       IsVisible="{Binding !IsRenaming}">
                                                <TextBlock.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Rename"
                                                                  Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).StartRenameChannelGroupCommand}"
                                                                  CommandParameter="{Binding}" />
                                                    </MenuFlyout>
                                                </TextBlock.ContextFlyout>
                                            </TextBlock>
                                            <!-- Rename input (visible when renaming) -->
                                            <TextBox Grid.Column="0" FontSize="11" Padding="4,2"
                                                     Text="{Binding RenamingText}"
                                                     IsVisible="{Binding IsRenaming}"
                                                     KeyDown="RenameChannelGroup_KeyDown" />
                                            <Button Grid.Column="1" Padding="2" Height="18" Width="18"
                                                    Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).ShowAddChannelDialogCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Add channel">
                                                <mi:MaterialIcon Kind="Plus" Width="12" Height="12" Opacity="0.5" />
                                            </Button>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Channels}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ChannelItem">
                                                    <Border CornerRadius="4"
                                                            Margin="0,1"
                                                            Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}">
                                                        <Button HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left"
                                                                Padding="12,6"
                                                                Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).SelectChannelCommand}"
                                                                CommandParameter="{Binding}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <mi:MaterialIcon Kind="Pound" Width="14" Height="14"
                                                                                 IsVisible="{Binding IsTextOnly}" />
                                                                <mi:MaterialIcon Kind="VolumeHigh" Width="14" Height="14"
                                                                                 IsVisible="{Binding !IsTextOnly}" />
                                                                <TextBlock Text="{Binding Name}" />
                                                            </StackPanel>
                                                        </Button>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right: Chat area -->
        <DockPanel Grid.Column="1">
            <!-- Channel header -->
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <mi:MaterialIcon Kind="Pound" Width="16" Height="16" Opacity="0.5" />
                    <TextBlock Classes="H4" Text="{Binding SelectedChannel.Name}" />
                </StackPanel>
            </Border>

            <!-- Message input -->
            <Border DockPanel.Dock="Bottom" Padding="16,8"
                    IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Panel>
                    <Popup x:Name="AutocompletePopup"
                           PlacementTarget="{Binding #MessageTextBox}"
                           Placement="Top"
                           IsLightDismissEnabled="False"
                           IsOpen="False">
                        <views:ShortcodeAutocompleteView x:Name="AutocompleteView" />
                    </Popup>
                    <Border BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource LgCornerRadius}"
                            Padding="0,4">
                        <Border.Styles>
                            <Style Selector="TextBox.Naked /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="TextBox.Naked:pointerover /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                            <Style Selector="TextBox.Naked:focus /template/ Border#Border">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </Border.Styles>
                        <Grid RowDefinitions="Auto * Auto">
                            <!-- Attachment preview strip -->
                            <ItemsControl Grid.Row="0" ItemsSource="{Binding Attachments}"
                                          IsVisible="{Binding Attachments.Count}"
                                          Margin="8,4,8,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AttachmentItem">
                                        <Border Background="{DynamicResource SecondaryColor50}"
                                                CornerRadius="6" Padding="8,4" Margin="0,0,4,4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <mi:MaterialIcon Kind="File" Width="14" Height="14" Opacity="0.7"
                                                                 VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                                           VerticalAlignment="Center" MaxWidth="160"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Classes="Ghost" Padding="2" MinWidth="0" MinHeight="0"
                                                        Width="18" Height="18"
                                                        Command="{Binding $parent[UserControl].((vm:ServerViewModel)DataContext).RemoveAttachmentCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Remove">
                                                    <mi:MaterialIcon Kind="Close" Width="12" Height="12" Opacity="0.5" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Grid.Row="1" ColumnDefinitions="* Auto Auto Auto" MinHeight="32">
                                <TextBox x:Name="MessageTextBox"
                                         Classes="Naked"
                                         Watermark="{Binding SelectedChannel.Name, StringFormat='Message #{0}'}"
                                         Text="{Binding MessageText}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         FontSize="15"
                                         Padding="14,8"
                                         shadui:ControlAssist.Height="100" />
                                <Button x:Name="AttachFileButton"
                                        Grid.Column="1"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="2,4,0,0"
                                        Padding="0"
                                        ToolTip.Tip="Attach file"
                                        Click="AttachFileButton_Click">
                                    <mi:MaterialIcon Kind="Paperclip" Width="18" Height="18" Opacity="0.5" />
                                </Button>
                                <Button x:Name="EmojiButton"
                                        Grid.Column="2"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="2,4,0,0"
                                        Padding="0"
                                        ToolTip.Tip="Emoji">
                                    <Button.Flyout>
                                        <Flyout Placement="TopEdgeAlignedRight" ShowMode="TransientWithDismissOnPointerMoveAway"
                                               FlyoutPresenterClasses="PopupPanel">
                                            <views:EmojiPickerView x:Name="EmojiPicker" />
                                        </Flyout>
                                    </Button.Flyout>
                                    <TextBlock FontSize="20" Text="&#x1F60A;" />
                                </Button>
                                <Button Grid.Column="3"
                                        Classes="Ghost"
                                        VerticalAlignment="Top"
                                        Width="32" Height="32"
                                        Margin="0,4,6,0"
                                        Padding="0"
                                        ToolTip.Tip="Send"
                                        Command="{Binding SendMessageCommand}">
                                    <mi:MaterialIcon Kind="Send" Width="18" Height="18" Opacity="0.5" />
                                </Button>
                            </Grid>
                            <TextBlock Grid.Row="2"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,4"
                                       FontSize="11"
                                       IsVisible="{Binding ShowCharCount}"
                                       Text="{Binding MessageCharsRemaining, StringFormat='{}{0}'}"
                                       Foreground="{Binding IsOverLimit, Converter={StaticResource OverLimitBrushConverter}}"
                                       Opacity="0.7" />
                        </Grid>
                    </Border>
                </Panel>
            </Border>

            <!-- Messages or placeholder -->
            <Panel>
                <!-- Placeholder when no channel selected -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNull}}">
                    <mi:MaterialIcon Kind="MessageText" Width="48" Height="48" Opacity="0.3"
                                     HorizontalAlignment="Center" />
                    <TextBlock Classes="Muted" Text="Select a channel to start chatting"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Message list -->
                <ScrollViewer x:Name="MessageScrollViewer" IsVisible="{Binding SelectedChannel, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ItemsControl ItemsSource="{Binding Messages}" Margin="16,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageItem">
                                <StackPanel>
                                    <!-- Time separator for messages with a gap -->
                                    <Grid ColumnDefinitions="* Auto *" Margin="0,16,0,4"
                                          IsVisible="{Binding ShowTimeSeparator}">
                                        <Separator Grid.Column="0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding TimeSeparatorText}"
                                                   Classes="Muted" FontSize="12" Margin="12,0" />
                                        <Separator Grid.Column="2" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Author header (avatar + name) — only shown for first message in a group -->
                                    <StackPanel Orientation="Horizontal" Spacing="10"
                                                Margin="0,12,0,4"
                                                IsVisible="{Binding ShowAuthor}">
                                        <shadui:Avatar Fallback="{Binding AvatarFallback}" Height="32" Width="32" />
                                        <TextBlock Text="{Binding AuthorName}" FontWeight="SemiBold"
                                                   FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding LocalTime}" Classes="Muted" FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Message content -->
                                    <Border CornerRadius="8"
                                            Padding="12,8"
                                            Margin="42,2,48,2"
                                            ToolTip.Tip="{Binding ExactTime}"
                                            Background="{DynamicResource SecondaryColor50}"
                                            Classes.selected="{Binding IsSelected}"
                                            PointerPressed="OnMessagePressed">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontFamily="Inter, fonts:NotoColorEmoji#Noto Color Emoji"
                                                       FontSize="{Binding IsEmojiOnly, Converter={StaticResource EmojiOnlyFontSizeConverter}}" />
                                            <Button Grid.Column="1"
                                                    VerticalAlignment="Top"
                                                    Padding="4" Margin="4,0,0,0"
                                                    Cursor="Hand"
                                                    Opacity="0"
                                                    Classes="ghost"
                                                    Tag="{Binding Content}"
                                                    Click="OnCopyMessageClick">
                                                <Button.Styles>
                                                    <Style Selector="Border:pointerover Button">
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </Style>
                                                    <Style Selector="Border:pointerover Button:pointerover">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Style>
                                                </Button.Styles>
                                                <mi:MaterialIcon Kind="ContentCopy" Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </DockPanel>
    </Grid>
</UserControl>
