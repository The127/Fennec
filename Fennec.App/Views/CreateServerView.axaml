<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shadui="using:ShadUI"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:Fennec.App.ViewModels"
             x:DataType="vm:CreateServerViewModel"
             x:Class="Fennec.App.Views.CreateServerView">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="400" Spacing="16" Margin="32">
        <mi:MaterialIcon Kind="Server" Width="48" Height="48" Opacity="0.5"
                         HorizontalAlignment="Center" />
        <TextBlock Classes="H3" Text="Create a Server" HorizontalAlignment="Center" />
        <TextBlock Classes="Muted" Text="Give your server a name and choose its visibility."
                   HorizontalAlignment="Center" Margin="0,0,0,8" />

        <StackPanel Spacing="4">
            <TextBlock Text="Server name" FontWeight="Bold" FontSize="12" />
            <TextBox Text="{Binding ServerName}" Watermark="My awesome server" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Visibility" FontWeight="Bold" FontSize="12" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Public" IsChecked="{Binding IsPublic}" GroupName="Visibility" />
                <RadioButton Content="Private" IsChecked="{Binding !IsPublic}" GroupName="Visibility" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <Button Content="Create Server"
                Command="{Binding CreateServerCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Classes="Primary"
                IsEnabled="{Binding !IsCreating}" />
    </StackPanel>
</UserControl>
