<shadui:Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Fennec.App.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:shadui="using:ShadUI"
        x:Class="Fennec.App.Views.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Fennec">
        <views:MainView />
        <Window.Resources>
                <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                        <Bitmap x:Key="LoginBackground">/Assets/pretty-triangles.png</Bitmap>
                                </ResourceDictionary>

                                <ResourceDictionary x:Key="Dark">
                                        <Bitmap x:Key="LoginBackground">/Assets/pretty-triangles-dark.png</Bitmap>
                                </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
        </Window.Resources>
</shadui:Window>
