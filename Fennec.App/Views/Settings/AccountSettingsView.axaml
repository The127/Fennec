<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Fennec.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Fennec.App.Views.Settings.AccountSettingsView"
             x:DataType="vm:AccountSettingsViewModel">
    <StackPanel Spacing="16" Margin="0,8">
        <StackPanel Spacing="4">
            <TextBlock Text="Username" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Username}" Classes="Muted" />
        </StackPanel>
        <StackPanel Spacing="4">
            <TextBlock Text="Server URL" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ServerUrl}" Classes="Muted" />
        </StackPanel>
    </StackPanel>
</UserControl>
