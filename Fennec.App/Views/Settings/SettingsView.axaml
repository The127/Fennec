<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Fennec.App.ViewModels.Settings"
             xmlns:mi="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Fennec.App.Views.Settings.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Border ClipToBounds="True">
        <Grid ColumnDefinitions="220 *">
            <!-- Sidebar -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />
                    <ListBox ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SettingsCategory">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="{Binding Icon}" Width="18" Height="18" />
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Content Area -->
            <DockPanel Grid.Column="1">
                <!-- Header -->
                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedCategory.Label}"
                           FontSize="18" FontWeight="SemiBold"
                           Margin="24,16,16,0" />

                <!-- Content -->
                <ContentControl Content="{Binding SelectedCategory.ViewModel}"
                                Margin="24,16" />
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
