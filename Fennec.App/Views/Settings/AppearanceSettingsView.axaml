<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Fennec.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Fennec.App.Views.Settings.AppearanceSettingsView"
             x:DataType="vm:AppearanceSettingsViewModel">
    <StackPanel Spacing="16" Margin="0,8">
        <StackPanel Spacing="8">
            <TextBlock Text="Theme" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding AvailablePalettes}"
                      SelectedItem="{Binding SelectedPalette}"
                      MinWidth="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock Text="Mode" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding AvailableModes}"
                      SelectedItem="{Binding SelectedMode}"
                      MinWidth="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
    </StackPanel>
</UserControl>
