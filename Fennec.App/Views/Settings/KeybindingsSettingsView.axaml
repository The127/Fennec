<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Fennec.App.ViewModels.Settings"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="Fennec.App.Views.Settings.KeybindingsSettingsView"
             x:DataType="vm:KeybindingsSettingsViewModel">
    <DockPanel>
        <!-- Conflict message banner -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource DestructiveColor}"
                CornerRadius="4" Padding="8,4" Margin="0,0,0,8"
                IsVisible="{Binding ConflictMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ConflictMessage}"
                       Foreground="White" FontSize="12" />
        </Border>

        <!-- Mouse button bindings -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="6">
            <TextBlock Text="Mouse Buttons" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2" />
            <ItemsControl ItemsSource="{Binding MouseBindings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MouseBindingItem">
                        <Grid ColumnDefinitions="*,200,70" Margin="0,2">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DisplayName}"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding $parent[UserControl].((vm:KeybindingsSettingsViewModel)DataContext).AllKeyboardBindings}"
                                      SelectedItem="{Binding SelectedBinding}"
                                      SelectionChanged="OnMouseSelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="2"
                                    Content="Reset"
                                    FontSize="11"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsModified}"
                                    Command="{Binding $parent[UserControl].((vm:KeybindingsSettingsViewModel)DataContext).ResetMouseBindingCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Bindings}"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action"
                                    Binding="{Binding DisplayName}"
                                    Width="*" />
                <DataGridTemplateColumn Header="Shortcut"
                                        Width="200"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ShortcutBindingItem">
                            <Panel>
                                <!-- Normal state: click to edit -->
                                <Border Background="{DynamicResource SecondaryColor}"
                                        CornerRadius="4" Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        IsVisible="{Binding !IsCapturing}"
                                        PointerPressed="OnShortcutPressed">
                                    <TextBlock Text="{Binding GestureText}"
                                               FontFamily="Consolas,Menlo,monospace"
                                               FontSize="12" />
                                </Border>

                                <!-- Capture state -->
                                <Border Background="{DynamicResource PrimaryColor}"
                                        CornerRadius="4" Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding IsCapturing}"
                                        Focusable="True"
                                        Name="CaptureBox"
                                        KeyDown="OnCaptureKeyDown"
                                        LostFocus="OnCaptureLostFocus">
                                    <TextBlock Text="Press shortcut..."
                                               FontFamily="Consolas,Menlo,monospace"
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryForegroundColor}"
                                               FontStyle="Italic" />
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Context"
                                    Binding="{Binding ContextLabel}"
                                    Width="100" />
                <DataGridTemplateColumn Header=""
                                        Width="70"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:ShortcutBindingItem">
                            <Button Content="Reset"
                                    FontSize="11"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsModified}"
                                    Command="{Binding $parent[DataGrid].((vm:KeybindingsSettingsViewModel)DataContext).ResetBindingCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
