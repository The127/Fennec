<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:routing="clr-namespace:Fennec.App.Routing"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:shadui="using:ShadUI"
             x:Class="Fennec.App.Views.MainAppView"
             xmlns:vm="using:Fennec.App.ViewModels"
             xmlns:ctrls="using:Fennec.App.Controls"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:DataType="vm:MainAppViewModel">
    <Panel>
    <DockPanel LastChildFill="True">
        <Border Padding="8" DockPanel.Dock="Left">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top"
                    Orientation="Vertical"
                    Spacing="8">
                    <Button Height="40" Width="40" Command="{Binding NavigateToDashboardCommand}">
                        <ctrls:FennecLogo/>
                    </Button>
                    <Button Height="40" Width="40" Command="{Binding NavigateToFriendsCommand}">
                        <mi:MaterialIcon Kind="AccountGroup" Width="20" Height="20" />
                    </Button>
                    <Separator Margin="4,4" />
                    <ItemsControl ItemsSource="{Binding Servers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SidebarServer">
                                <Button Height="40" Width="40" Margin="0,0,0,8"
                                        Command="{Binding $parent[UserControl].((vm:MainAppViewModel)DataContext).NavigateToServerCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{Binding Name}">
                                    <Button.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Create Invite Link"
                                                      Command="{Binding $parent[UserControl].((vm:MainAppViewModel)DataContext).CreateInviteLinkCommand}"
                                                      CommandParameter="{Binding}" />
                                        </MenuFlyout>
                                    </Button.ContextFlyout>
                                    <shadui:Avatar Fallback="{Binding AvatarFallback}" Height="32" Width="32" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Margin="4,0,4,4" />
                    <Button Height="40" Width="40" Command="{Binding NavigateToAddCommand}">
                        <mi:MaterialIcon Kind="Plus" Width="20" Height="20" />
                    </Button>
                </StackPanel>
                <!-- Global voice indicator -->
                <StackPanel DockPanel.Dock="Bottom" Spacing="4"
                            IsVisible="{Binding IsInVoiceCall}">
                    <Button Classes="Ghost" Padding="4"
                            Command="{Binding NavigateToVoiceChannelCommand}"
                            ToolTip.Tip="Go to voice channel"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="Headphones" Width="16" Height="16"
                                             Foreground="{DynamicResource SuccessColor}"
                                             HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding VoiceServerName}"
                                       FontSize="9" TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="36" />
                        </StackPanel>
                    </Button>
                    <UniformGrid Columns="3" HorizontalAlignment="Center">
                        <Button Classes="Ghost" Padding="2" Width="24" Height="24"
                                Command="{Binding ToggleVoiceMuteCommand}"
                                ToolTip.Tip="Toggle Mute">
                            <Panel>
                                <mi:MaterialIcon Kind="Microphone" Width="12" Height="12"
                                                 IsVisible="{Binding !IsVoiceMuted}" />
                                <mi:MaterialIcon Kind="MicrophoneOff" Width="12" Height="12"
                                                 Foreground="{DynamicResource ErrorColor}"
                                                 IsVisible="{Binding IsVoiceMuted}" />
                            </Panel>
                        </Button>
                        <Button Classes="Ghost" Padding="2" Width="24" Height="24"
                                Command="{Binding ToggleVoiceDeafenCommand}"
                                ToolTip.Tip="Toggle Deafen">
                            <Panel>
                                <mi:MaterialIcon Kind="VolumeHigh" Width="12" Height="12"
                                                 IsVisible="{Binding !IsVoiceDeafened}" />
                                <mi:MaterialIcon Kind="VolumeOff" Width="12" Height="12"
                                                 Foreground="{DynamicResource ErrorColor}"
                                                 IsVisible="{Binding IsVoiceDeafened}" />
                            </Panel>
                        </Button>
                        <Button Classes="Ghost" Padding="2" Width="24" Height="24"
                                Command="{Binding LeaveVoiceCallCommand}"
                                ToolTip.Tip="Disconnect">
                            <mi:MaterialIcon Kind="PhoneHangup" Width="12" Height="12"
                                             Foreground="{DynamicResource ErrorColor}" />
                        </Button>
                    </UniformGrid>
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Height="40" Width="40" Command="{Binding NavigateToCallsCommand}">
                    <mi:MaterialIcon Kind="Phone" Width="20" Height="20" />
                </Button>
            </DockPanel>
        </Border>
        <StackPanel DockPanel.Dock="Top">
            <Border Padding="8">
                <Grid ColumnDefinitions="* Auto *">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="2">
                        <Button Height="32" Width="32"
                                Command="{Binding NavigateBackCommand}"
                                ToolTip.Tip="Back (Alt+Left)">
                            <mi:MaterialIcon Kind="ArrowLeft" Width="16" Height="16" />
                        </Button>
                        <Button Height="32" Width="32"
                                Command="{Binding NavigateForwardCommand}"
                                ToolTip.Tip="Forward (Alt+Right)">
                            <mi:MaterialIcon Kind="ArrowRight" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                    <TextBox
                        Grid.Column="1"
                        x:Name="SearchBox"
                        Classes="Clearable"
                        Text="{Binding SearchText}"
                        Watermark="{Binding SearchWatermark}"
                        VerticalAlignment="Center"
                        Width="256"
                        GotFocus="SearchBox_GotFocus">
                        <TextBox.InnerRightContent>
                            <PathIcon
                                Data="{x:Static shadui:Icons.Search}"
                                Opacity="0.75"
                                Width="16" />
                        </TextBox.InnerRightContent>
                    </TextBox>
                    <shadui:SimpleDropdown
                        Grid.Column="2"
                        x:Name="ProfileDropdown"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        PopupPlacement="BottomEdgeAlignedRight"
                        PopupWidth="200">
                        <shadui:SimpleDropdown.TriggerContent>
                            <Grid ColumnDefinitions="Auto * Auto" Margin="0">
                                <shadui:Avatar
                                    Fallback="{Binding AvatarFallback}"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Width="36" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Username}" />
                                    <TextBlock
                                        Classes="Muted"
                                        FontSize="10"
                                        Margin="0,-4,0,0"
                                        Text="{Binding UserAtServer}" />
                                </StackPanel>
                            </Grid>
                        </shadui:SimpleDropdown.TriggerContent>
                        <!-- Mode toggle: Light / Auto / Dark -->
                        <Border Background="{DynamicResource SecondaryColor}"
                                CornerRadius="8"
                                Padding="3"
                                Margin="4">
                            <UniformGrid Columns="3">
                                <Button Classes="modeButton"
                                        Command="{Binding SetThemeModeCommand}"
                                        CommandParameter="Light"
                                        Tag="{Binding IsLightMode}"
                                        HorizontalAlignment="Stretch">
                                    <mi:MaterialIcon Kind="WeatherSunny" Width="16" Height="16" />
                                </Button>
                                <Button Classes="modeButton"
                                        Command="{Binding SetThemeModeCommand}"
                                        CommandParameter="Auto"
                                        Tag="{Binding IsAutoMode}"
                                        HorizontalAlignment="Stretch">
                                    <mi:MaterialIcon Kind="BrightnessAuto" Width="16" Height="16" />
                                </Button>
                                <Button Classes="modeButton"
                                        Command="{Binding SetThemeModeCommand}"
                                        CommandParameter="Dark"
                                        Tag="{Binding IsDarkMode}"
                                        HorizontalAlignment="Stretch">
                                    <mi:MaterialIcon Kind="WeatherNight" Width="16" Height="16" />
                                </Button>
                            </UniformGrid>
                        </Border>
                        <MenuItem Header="Profile" Click="ProfileMenuItem_Click" />
                        <MenuItem Header="Switch Account" Click="SwitchAccountMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="Logout" Command="{Binding LogoutCommand}" Click="ProfileMenuItem_Click" />
                        <MenuItem Header="Settings" Click="SettingsMenuItem_Click" />
                    </shadui:SimpleDropdown>
                </Grid>
            </Border>
        </StackPanel>
        <routing:RouteView Router="{Binding Router}" />
    </DockPanel>

    <!-- Floating screen share PiP overlay -->
    <Border x:Name="FloatingPip"
            IsVisible="{Binding ShowFloatingScreenShare}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,16,16"
            Width="320" Height="200"
            CornerRadius="8"
            ClipToBounds="True"
            Background="#FF1A1A1A"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Cursor="Hand"
            PointerPressed="FloatingPip_PointerPressed"
            PointerMoved="FloatingPip_PointerMoved"
            PointerReleased="FloatingPip_PointerReleased">
        <Grid>
            <ctrls:ScreenShareViewer Source="{Binding FloatingScreenShareFrame}"
                                     CursorX="{Binding FloatingCursorX}"
                                     CursorY="{Binding FloatingCursorY}" />
            <!-- Title bar -->
            <Border VerticalAlignment="Top" Padding="8,4"
                    Background="#80000000">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Classes="Ghost" Padding="4" Width="24" Height="24"
                            Command="{Binding NavigateToFloatingScreenShareCommand}"
                            ToolTip.Tip="Go to channel">
                        <mi:MaterialIcon Kind="ArrowExpand" Width="12" Height="12" />
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="Monitor" Width="12" Height="12" />
                        <TextBlock Text="{Binding FloatingSharerUsername}" FontSize="11"
                                   Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
    </Panel>
</UserControl>