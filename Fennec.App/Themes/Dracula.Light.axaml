<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dracula Light (Alucard) — https://draculatheme.com/pro
         Background #F5F5F5, LineHighlight #DCDEEF, Selection #CFCFDE
         Foreground #1F1F1F, Comment #635D97
         Purple #644AC9, Pink #A3134D, Red #CB3A2A, Orange #A34D14
         Yellow #836E15, Green #14720A, Cyan #036A96 -->

    <!-- basic colors -->
    <Color x:Key="ForegroundColor">#1F1F1F</Color>
    <Color x:Key="ForegroundLeadColor">#635D97</Color>
    <Color x:Key="MutedColor">#635D97</Color>
    <Color x:Key="BorderColor">#CFCFDE</Color>
    <Color x:Key="BorderColor60">#DCDEEF</Color>
    <Color x:Key="BorderColor30">#4CCFCFDE</Color>
    <Color x:Key="OutlineColor">#DCDEEF</Color>
    <Color x:Key="GhostColor">#EEEEF5</Color>
    <Color x:Key="GhostHoverColor">#7FEEEEF5</Color>
    <Color x:Key="SelectionColor">#0C1F1F1F</Color>

    <!-- theme colors — primary=Purple, destructive=Red -->
    <Color x:Key="PrimaryColor">#644AC9</Color>
    <Color x:Key="PrimaryColor75">#BF644AC9</Color>
    <Color x:Key="PrimaryColor50">#80644AC9</Color>
    <Color x:Key="PrimaryColor10">#19644AC9</Color>
    <Color x:Key="PrimaryForegroundColor">#F5F5F5</Color>
    <Color x:Key="SecondaryColor">#DCDEEF</Color>
    <Color x:Key="SecondaryColor75">#BFDCDEEF</Color>
    <Color x:Key="SecondaryColor50">#80DCDEEF</Color>
    <Color x:Key="SecondaryForegroundColor">#1F1F1F</Color>
    <Color x:Key="DestructiveColor">#CB3A2A</Color>
    <Color x:Key="DestructiveColor75">#BFCB3A2A</Color>
    <Color x:Key="DestructiveColor50">#80CB3A2A</Color>
    <Color x:Key="DestructiveColor10">#19CB3A2A</Color>
    <Color x:Key="DestructiveForegroundColor">#F5F5F5</Color>

    <!-- control colors — purple-tinted greys -->
    <Color x:Key="CardBackgroundColor">#F5F5FA</Color>
    <Color x:Key="DialogBackgroundColor">#EEEEF5</Color>
    <Color x:Key="DialogOverlayColor">#000000</Color>
    <Color x:Key="TitleBarBackgroundColor">#E8E8F0</Color>
    <Color x:Key="WindowBackgroundColor">#F5F5F5</Color>
    <Color x:Key="SidebarBackgroundColor">#E8E8F0</Color>
    <Color x:Key="SwitchBackgroundColor">#CFCFDE</Color>
    <Color x:Key="SwitchForegroundColor">#FFFFFF</Color>
    <Color x:Key="TabItemSelectedColor">#F5F5FA</Color>
    <Color x:Key="TabItemsBackgroundColor">#DCDEEF</Color>

    <!-- notification colors -->
    <Color x:Key="InfoColor">#036A96</Color>
    <Color x:Key="SuccessColor">#14720A</Color>
    <Color x:Key="WarningColor">#A34D14</Color>
    <Color x:Key="ErrorColor">#CB3A2A</Color>
</ResourceDictionary>
