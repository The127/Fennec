# Smoke test environment config — copy to smoke.env and fill in your values.
# k8s/smoke.env is gitignored and sourced by the justfile smoke-* recipes.

# SSH hostname (or alias) for the k3s node
SMOKE_K3S_HOST=my-k3s-node

# LAN IP of the k3s node (used in hostAliases so pods resolve the domain)
SMOKE_NODE_IP=192.168.1.82

# Domain pointing to the k3s node (TLS cert must match)
SMOKE_DOMAIN=fennec.example.com

# LAN IP of the Mac Mini running the second app instance
SMOKE_MINI_IP=192.168.1.29

# SSH user on the Mac Mini
SMOKE_MINI_SSH_USER=myuser

# Absolute path on the k3s node where source is rsynced for mac-launcher hostPath
SMOKE_SOURCE_PATH=/home/me/fennec-smoke-src
